#### Step 2: Stripe Subscription Service

**File:** `WahadiniCryptoQuest.Application/Services/StripeSubscriptionService.cs`

```csharp
using Microsoft.Extensions.Configuration;
using Stripe;
using Stripe.Checkout;
using WahadiniCryptoQuest.Domain.Entities;
using WahadiniCryptoQuest.Application.Interfaces;

public class StripeSubscriptionService : ISubscriptionService
{
    private readonly IConfiguration _config;
    // Assume UserManager and DbContext are injected

    public StripeSubscriptionService(IConfiguration config)
    {
        _config = config;
        StripeConfiguration.ApiKey = _config["Stripe:SecretKey"];
    }

    public async Task<string> CreateCheckoutSessionAsync(User user, string priceId, string? discountCode)
    {
        var options = new SessionCreateOptions
        {
            Customer = user.StripeCustomerId, // Ensure customer exists
            Mode = "subscription",
            PaymentMethodTypes = new List<string> { "card" },
            LineItems = new List<SessionLineItemOptions>
            {
                new SessionLineItemOptions
                {
                    Price = priceId,
                    Quantity = 1,
                },
            },
            SuccessUrl = _config["App:ClientUrl"] + "/payment/success?session_id={CHECKOUT_SESSION_ID}",
            CancelUrl = _config["App:ClientUrl"] + "/payment/cancel",
            Metadata = new Dictionary<string, string>
            {
                { "userId", user.Id.ToString() },
                { "discountCode", discountCode ?? "" }
            }
        };

        // Create new customer if not exists
        if (string.IsNullOrEmpty(user.StripeCustomerId))
        {
            var customerOptions = new CustomerCreateOptions
            {
                Email = user.Email,
                Name = user.Username,
                Metadata = new Dictionary<string, string> { { "userId", user.Id.ToString() } }
            };
            var customerService = new CustomerService();
            var customer = await customerService.CreateAsync(customerOptions);
            user.StripeCustomerId = customer.Id;
            // Update User in DB
            
            options.Customer = customer.Id;
        }

        // Apply Discount
        if (!string.IsNullOrEmpty(discountCode))
        {
             // Verify discount valid code logic here
             // For simplicity, assuming a Promotion Code ID is resolved
             // options.Discounts = new List<SessionDiscountOptions> { ... };
        }

        var service = new SessionService();
        Session session = await service.CreateAsync(options);
        return session.Url;
    }

    public async Task<string> CreatePortalSessionAsync(string stripeCustomerId)
    {
        var options = new Stripe.BillingPortal.SessionCreateOptions
        {
            Customer = stripeCustomerId,
            ReturnUrl = _config["App:ClientUrl"] + "/profile",
        };
        var service = new Stripe.BillingPortal.SessionService();
        var session = await service.CreateAsync(options);
        return session.Url;
    }
}
```

#### Step 3: Webhook Controller

**File:** `WahadiniCryptoQuest.API/Controllers/WebhookController.cs`

```csharp
using Microsoft.AspNetCore.Mvc;
using Stripe;
using System.IO;

[Route("api/webhooks")]
[ApiController]
public class WebhookController : ControllerBase
{
    private readonly string _webhookSecret;
    private readonly IServiceProvider _serviceProvider;

    public WebhookController(IConfiguration config, IServiceProvider serviceProvider)
    {
        _webhookSecret = config["Stripe:WebhookSecret"];
        _serviceProvider = serviceProvider;
    }

    [HttpPost("stripe")]
    public async Task<IActionResult> HandleStripeWebhook()
    {
        var json = await new StreamReader(HttpContext.Request.Body).ReadToEndAsync();
        
        try
        {
            var stripeEvent = EventUtility.ConstructEvent(json, Request.Headers["Stripe-Signature"], _webhookSecret);

            using var scope = _serviceProvider.CreateScope();
            var dbContext = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
            var userManager = scope.ServiceProvider.GetRequiredService<UserManager<User>>();

            switch (stripeEvent.Type)
            {
                case Events.CheckoutSessionCompleted:
                    var session = stripeEvent.Data.Object as Stripe.Checkout.Session;
                    await HandleCheckoutCompleted(session, dbContext, userManager);
                    break;

                case Events.CustomerSubscriptionDeleted:
                    var subscription = stripeEvent.Data.Object as Stripe.Subscription;
                    await HandleSubscriptionEnded(subscription, dbContext);
                    break;
                
                case Events.InvoicePaymentSucceeded:
                    var invoice = stripeEvent.Data.Object as Stripe.Invoice;
                    await HandleInvoicePaid(invoice, dbContext);
                    break;
            }

            return Ok();
        }
        catch (StripeException e)
        {
            return BadRequest(e.Message);
        }
    }

    private async Task HandleCheckoutCompleted(Stripe.Checkout.Session session, ApplicationDbContext db, UserManager<User> userManager)
    {
        // Get user by StripeCustomerId or Metadata
        var userId = session.Metadata["userId"];
        var user = await userManager.FindByIdAsync(userId);
        
        if (user != null)
        {
            user.StripeCustomerId = session.CustomerId;
            user.StripeSubscriptionId = session.SubscriptionId;
            user.SubscriptionTier = "Premium"; // Determine based on Price ID logic
            user.SubscriptionStatus = "active";
            // Mark discount as used if applicable
            await db.SaveChangesAsync();
        }
    }

    // Additional helper methods...
}
```

#### Step 4: Frontend Pricing Page

**File:** `src/pages/PricingPage.tsx`

```tsx
import React from 'react';
import { useAuth } from '../hooks/useAuth';
import api from '../services/api';

const PricingPage = () => {
  const { user } = useAuth();

  const handleSubscribe = async (planId: string) => {
    try {
      const response = await api.post('/subscriptions/checkout', { planId });
      // Redirect to Stripe Checkout
      window.location.href = response.data.sessionUrl;
    } catch (error) {
      console.error("Checkout failed", error);
    }
  };

  return (
    <div className="container mx-auto py-12">
      <h1 className="text-4xl font-bold text-center mb-8">Choose Your Plan</h1>
      
      <div className="grid md:grid-cols-3 gap-8">
        {/* Free Tier */}
        <div className="border rounded-lg p-6 shadow-md bg-white dark:bg-gray-800">
          <h2 className="text-2xl font-bold mb-4">Free</h2>
          <p className="text-3xl font-bold mb-6">$0<span className="text-sm font-normal">/mo</span></p>
          <ul className="mb-6 space-y-2">
            <li>✓ Access to Free Courses</li>
            <li>✓ 5 Tasks per day</li>
            <li>✗ Ad-supported</li>
          </ul>
          <button className="w-full py-2 bg-gray-200 text-gray-800 rounded mt-auto" disabled>Current Plan</button>
        </div>

        {/* Monthly Premium */}
        <div className="border-2 border-indigo-500 rounded-lg p-6 shadow-xl relative bg-white dark:bg-gray-800 transform scale-105">
          <div className="absolute top-0 right-0 bg-indigo-500 text-white px-3 py-1 text-sm rounded-bl-lg">Popular</div>
          <h2 className="text-2xl font-bold mb-4">Monthly Premium</h2>
          <p className="text-3xl font-bold mb-6">$9.99<span className="text-sm font-normal">/mo</span></p>
          <ul className="mb-6 space-y-2">
             <li>✓ All Courses Access</li>
             <li>✓ Unlimited Tasks</li>
             <li>✓ No Ads</li>
             <li>✓ Priority Support</li>
          </ul>
          <button 
            onClick={() => handleSubscribe('price_monthly_id')} 
            className="w-full py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded font-bold"
          >
            Subscribe Monthly
          </button>
        </div>

        {/* Yearly Premium */}
        <div className="border rounded-lg p-6 shadow-md bg-white dark:bg-gray-800">
          <h2 className="text-2xl font-bold mb-4">Yearly Premium</h2>
          <p className="text-3xl font-bold mb-6">$99<span className="text-sm font-normal">/year</span></p>
          <ul className="mb-6 space-y-2">
             <li>✓ Everything in Monthly</li>
             <li>✓ 2 Months Free (17% off)</li>
             <li>✓ Certificate of Completion</li>
             <li>✓ 1-on-1 Consultation</li>
          </ul>
          <button 
             onClick={() => handleSubscribe('price_yearly_id')}
             className="w-full py-2 bg-purple-600 hover:bg-purple-700 text-white rounded"
          >
            Subscribe Yearly
          </button>
        </div>
      </div>
    </div>
  );
};

export default PricingPage;
```
